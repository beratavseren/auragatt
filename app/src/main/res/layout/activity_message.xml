<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/topBarImage"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="18dp"
        android:scaleType="fitXY"
        android:src="@drawable/top_nav_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnLightning"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBarImage" />

    <RelativeLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="105dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/bottom_nav_bar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <FrameLayout
                android:id="@+id/navMessage"
                android:contentDescription="Messages Navigation Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
            <FrameLayout
                android:id="@+id/navHome"
                android:contentDescription="Home Navigation Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
            <FrameLayout
                android:id="@+id/navProfile"
                android:contentDescription="Profile Navigation Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/layoutInputBar"
        android:layout_width="match_parent"
        android:layout_height="69dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/mesaj_kutusu"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <EditText
            android:id="@+id/edtMessageInput"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="25dp"
            android:layout_toStartOf="@id/btnSendMessage"
            android:background="@android:color/transparent"
            android:fontFamily="@font/nova_flat_regular"
            android:gravity="center_vertical"
            android:hint="Mesaj yazın..."
            android:textColorHint="@color/gray_text"
            android:inputType="textShortMessage"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/btnSendMessage"
            android:layout_width="60dp"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:padding="12dp"
            android:src="@drawable/send_button"
            android:contentDescription="Send Message Button"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <ImageView
        android:id="@+id/btnLightning"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:elevation="10dp"
        android:focusable="true"
        android:src="@drawable/sarj_image"
        android:contentDescription="Quick Actions Button"
        app:layout_constraintBottom_toTopOf="@id/layoutInputBar"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutQuickActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="20dp"
        android:elevation="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnLightning"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnQuickEnkaz"
            android:layout_width="240dp"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_quick_action"
            android:fontFamily="@font/nova_flat_regular"
            android:gravity="center"
            android:text="Enkaz Altındayım"
            android:textColor="#333333"
            android:textSize="18sp"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnQuickYarali"
            android:layout_width="240dp"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_quick_action"
            android:fontFamily="@font/nova_flat_regular"
            android:gravity="center"
            android:text="Yaralıyım"
            android:textColor="#333333"
            android:textSize="18sp"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnQuickGuven"
            android:layout_width="240dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_quick_action"
            android:fontFamily="@font/nova_flat_regular"
            android:gravity="center"
            android:text="Güvendeyim"
            android:textColor="#333333"
            android:textSize="18sp"
            android:elevation="6dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>