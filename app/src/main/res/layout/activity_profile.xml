<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/topBarImage"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="18dp"
        android:scaleType="fitXY"
        android:src="@drawable/top_nav_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/topBarImage"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nova_flat_regular"
                android:text="Profil"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/nova_flat_regular"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Aşağıdaki bilgiler acil durumlarda\nve bilincinizin kapalı olması\nhalinde ağdaki kişilere\niletilecektir."
                android:textColor="@color/white"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ad-Soyad"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nova_flat_regular"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>
                <EditText
                    android:id="@+id/edtFullName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/text_giris_kutusu"
                    android:fontFamily="@font/nova_flat_regular"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kan Grubu"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nova_flat_regular"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>
                <LinearLayout
                    android:id="@+id/bloodGroupBox"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/text_giris_kutusu"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:id="@+id/txtBloodGroup"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/nova_flat_regular"
                        android:gravity="center_vertical"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kronik Rahatsızlık"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nova_flat_regular"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>
                <EditText
                    android:id="@+id/edtChronic"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/text_giris_kutusu"
                    android:fontFamily="@font/nova_flat_regular"
                    android:paddingHorizontal="16dp"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Düzenli Kullanılan İlaçlar"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nova_flat_regular"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>
                <EditText
                    android:id="@+id/edtMedicine"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/text_giris_kutusu"
                    android:fontFamily="@font/nova_flat_regular"
                    android:paddingHorizontal="16dp"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alerjiler"
                    android:textColor="@color/white"
                    android:fontFamily="@font/nova_flat_regular"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>
                <EditText
                    android:id="@+id/edtAllergy"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/text_giris_kutusu"
                    android:fontFamily="@font/nova_flat_regular"
                    android:paddingHorizontal="16dp"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnSaveProfile"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/selector_btn_green"
                android:fontFamily="@font/nova_flat_regular"
                android:gravity="center"
                android:text="Kaydet"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </ScrollView>

    <RelativeLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="105dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/bottom_nav_profile" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <FrameLayout
                android:id="@+id/navMessage"
                android:contentDescription="Messages Navigation Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
            <FrameLayout
                android:id="@+id/navHome"
                android:contentDescription="Home Navigation Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
            <FrameLayout
                android:id="@+id/navProfile"
                android:contentDescription="Profile Navigation Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>