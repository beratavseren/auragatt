<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="150dp"
        android:gravity="center_horizontal">

        <!-- Başlık -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nova_flat_regular"
            android:text="Profil"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/nova_flat_regular"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Aşağıdaki bilgiler acil durumlarda\nve bilincinizin kapalı olması\nhalinde ağdaki kişilere\niletilecektir."
            android:textColor="@color/white"
            android:textSize="14sp" />

        <!-- FORM ALANI -->
        <RelativeLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <!-- Arka plandaki ana form görseli -->
            <ImageView
                android:id="@+id/imgProfileForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/profil" />

            <!-- 1. Ad-Soyad -->
            <EditText
                android:id="@+id/edtFullName"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_alignTop="@id/imgProfileForm"
                android:layout_marginTop="34dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/text_giris_kutusu"
                android:fontFamily="@font/nova_flat_regular"
                android:inputType="textPersonName"
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:gravity="center_vertical"
                android:hint="" />

            <!-- 2. Kan Grubu Seçim Kutusu -->
            <LinearLayout
                android:id="@+id/bloodGroupBox"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_alignTop="@id/imgProfileForm"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="111dp"
                android:background="@drawable/text_giris_kutusu"
                android:clickable="true"
                android:focusable="true"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/txtBloodGroup"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/nova_flat_regular"
                    android:gravity="center_vertical"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 3. Kronik Rahatsızlık -->
            <EditText
                android:id="@+id/edtChronic"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_alignTop="@id/imgProfileForm"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="186dp"
                android:background="@drawable/text_giris_kutusu"
                android:fontFamily="@font/nova_flat_regular"
                android:gravity="center_vertical"
                android:hint=""
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- 4. İlaçlar -->
            <EditText
                android:id="@+id/edtMedicine"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_alignTop="@id/imgProfileForm"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="255dp"
                android:background="@drawable/text_giris_kutusu"
                android:fontFamily="@font/nova_flat_regular"
                android:gravity="center_vertical"
                android:hint=""
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <!-- 5. Alerjiler -->
            <EditText
                android:id="@+id/edtAllergy"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_alignTop="@id/imgProfileForm"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="328dp"
                android:background="@drawable/text_giris_kutusu"
                android:fontFamily="@font/nova_flat_regular"
                android:gravity="center_vertical"
                android:hint=""
                android:paddingHorizontal="16dp"
                android:singleLine="true"
                android:textColor="@color/white"
                android:textSize="14sp" />

        </RelativeLayout>

        <!-- KAYDET BUTONU -->
        <TextView
            android:id="@+id/btnSaveProfile"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/button_green"
            android:fontFamily="@font/nova_flat_regular"
            android:gravity="center"
            android:text="Kaydet"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</ScrollView>