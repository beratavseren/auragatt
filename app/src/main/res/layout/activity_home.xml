<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_bg">

    <ImageView
        android:id="@+id/topBarImage"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginTop="18dp"
        android:scaleType="fitXY"
        android:src="@drawable/top_nav_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/btnSos"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:src="@drawable/selector_btn_sos"
            android:contentDescription="Afet Modu Başlat" />

        <TextView
            android:id="@+id/txtSosInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Afet Modunu Aktifleştirmek İçin\n3 Saniye Basılı Tutun"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:gravity="center"
            android:fontFamily="@font/nova_flat_regular" />

    </LinearLayout>

    <ImageView
        android:id="@+id/bottomNavImage"
        android:layout_width="match_parent"
        android:layout_height="105dp"
        android:layout_gravity="bottom"
        android:src="@drawable/bottom_nav_home"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="105dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal">
        <FrameLayout android:id="@+id/navMessage" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <FrameLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
        <FrameLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
    </LinearLayout>

</FrameLayout>